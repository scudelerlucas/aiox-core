# @aiox/omni-video-factory — configuracao
# Copie para .env (ou exporte no shell). Sem GEMINI_API_KEY o CLI roda em dry-run.

# Chave do Google Gemini API (aistudio.google.com/apikey). Aceita qualquer uma:
GEMINI_API_KEY=
# GOOGLE_API_KEY=
# OMNI_API_KEY=

# Modelos (defaults ja apontam para os corretos)
# OMNI_MODEL=gemini-omni-flash-preview
# VEO_MODEL=veo-3.1-generate-preview
# OMNI_API_BASE=https://generativelanguage.googleapis.com/v1beta

# Saida e personas
# OMNI_OUT_DIR=output
# OMNI_PERSONA_DIR=personas

# Polling da long-running operation
# OMNI_POLL_INTERVAL_MS=10000
# OMNI_POLL_TIMEOUT_MS=600000

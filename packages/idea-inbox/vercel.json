{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/**/*.mjs": { "maxDuration": 10 }
  },
  "rewrites": [
    { "source": "/health", "destination": "/api/health" },
    { "source": "/ingest", "destination": "/api/ingest" },
    { "source": "/webhook/telegram", "destination": "/api/webhook/telegram" },
    { "source": "/webhook/whatsapp", "destination": "/api/webhook/whatsapp" },
    { "source": "/dashboard", "destination": "/api/dashboard" },
    { "source": "/diagnose", "destination": "/api/diagnose" },
    { "source": "/report/:id", "destination": "/api/report?runId=:id" },
    { "source": "/runs/:id", "destination": "/api/runs?id=:id" }
  ]
}

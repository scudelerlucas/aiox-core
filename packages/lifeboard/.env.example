# OS-LIFEBOARD — variáveis de ambiente (SEM valores reais; camada G do CHC).
# Copie para .env.local e preencha só no ambiente server-side.

# Flip fixture (default, rodada atual) vs live (produção, após revisão manual).
LIFEBOARD_DATA_MODE=fixture

# Credenciais Google (camada G) — PAUSADAS nesta rodada; NUNCA versionar valores.
# Preenchidas só quando LIFEBOARD_DATA_MODE=live, via Vault/env server-side.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REFRESH_TOKEN=
